<view class="ai-mask {{visible ? 'show' : ''}}" bindtap="close" wx:if="{{visible}}"></view>
<view class="ai-popup" 
      animation="{{animationData}}" 
      wx:if="{{visible}}"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd">
  <view class="ai-header">
    <view class="drag-handle"></view>
    <view class="ai-title">讲解</view>
  </view>

  <scroll-view scroll-y class="ai-content" scroll-into-view="{{scrollToView}}" scroll-top="{{scrollTop}}">
    <block wx:for="{{messages}}" wx:key="index">
      <view class="message-row {{item.role === 'user' ? 'user-row' : 'ai-row'}}" id="msg-{{index}}" wx:if="{{item.role === 'user' || item.content}}">

        <!-- User Message -->
        <view class="bubble" wx:if="{{item.role === 'user'}}">
          <text user-select>{{item.content}}</text>
        </view>

        <!-- AI Message (Rich Text) -->
        <view class="bubble content-bubble" wx:else>
           <block wx:if="{{item.showStreamingText}}">
             <view class="streaming-text">
               <text user-select space="ensp">{{item.displayText || item.content}}</text>
               <text wx:if="{{item.isStreaming}}" class="typing-cursor">▌</text>
             </view>
           </block>
           <block wx:elif="{{item.showParsedNodes}}">
             <block wx:for="{{item.parsedNodes}}" wx:for-item="node" wx:key="nIdx" wx:for-index="nIdx">
                <!-- 标题（【翻译】、【词汇】等）-->
                <view wx:if="{{node.type === 'header'}}" class="md-header">{{node.content}}</view>

                <!-- 列表项 -->
                <view wx:elif="{{node.type === 'list-item'}}" class="md-list-item">{{node.content}}</view>

                <!-- 普通段落 -->
                <view wx:else class="md-p">{{node.content}}</view>
             </block>
           </block>
           <block wx:else>
             <view class="streaming-text">
               <text user-select space="ensp">{{item.content}}</text>
             </view>
           </block>
        </view>
      </view>
    </block>

    <!-- Loading Indicator (Show ONLY when waiting for first token) -->
    <view class="message-row ai-row" id="loading-indicator" wx:if="{{loading && (messages.length === 0 || messages[messages.length-1].role === 'user' || !messages[messages.length-1].content)}}">
      <view class="ai-avatar-placeholder"></view>
      <view class="bubble loading-bubble">
         <view class="dot-flashing">
            <view class="dot-flashing-item"></view>
            <view class="dot-flashing-item"></view>
            <view class="dot-flashing-item"></view>
         </view>
      </view>
    </view>
  </scroll-view>

  <view class="ai-footer">
    <input class="chat-input" 
           placeholder="请输入问题..." 
           value="{{inputValue}}" 
           bindinput="handleInput"
           bindconfirm="handleSend"
           confirm-type="send" />
    <view class="send-btn {{!inputValue || loading ? 'disabled' : ''}}" bindtap="handleSend">
      <view class="send-icon"></view>
    </view>
  </view>
</view>
