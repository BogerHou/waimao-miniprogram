<view class="app-page">
<navigation-bar title="交流与反馈" back="{{true}}" color="black" background="#FFF"></navigation-bar>

<scroll-view class="contact-scroll" scroll-y>
  <view class="contact-page">
    <view class="contact-heading">
      <image class="contact-heading__icon" src="/assets/images/icon.png" mode="aspectFill"></image>
      <text class="contact-heading__title">加入外贸英语交流群</text>
      <text class="contact-heading__desc">交流外贸场景表达，分享跟读打卡</text>
    </view>

    <view class="contact-qr" bindtap="previewQRCode" aria-role="button" aria-label="查看交流群二维码">
      <image class="contact-qr__image" src="{{qrCodeUrl}}" mode="widthFix" show-menu-by-longpress="{{true}}" />
    </view>
    <text class="contact-qr__tip">点击放大，长按识别二维码</text>
  </view>
</scroll-view>

<canvas
  canvas-id="contact-share-canvas"
  class="share-poster-canvas"
  style="width: 600px; height: 840px;"
></canvas>
</view>
