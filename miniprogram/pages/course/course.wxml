<wxs module="utils">
  var formatSpeed = function(speed) {
    if (speed % 1 === 0) return speed.toFixed(0)
    if ((speed * 10) % 1 === 0) return speed.toFixed(1)
    return speed.toFixed(2)
  }
  module.exports = { formatSpeed: formatSpeed }
</wxs>

<view class="app-page">
<view class="course-navbar">
  <navigation-bar
    title="{{course ? course.title : '课程练习'}}"
    back="{{true}}"
    color="black"
    background="#F5F7FB"
  ></navigation-bar>
</view>

<view class="course-page">
  <block wx:if="{{loading}}">
    <view class="course-skeleton" aria-label="课程加载中">
      <view class="course-skeleton__modes">
        <view class="course-skeleton__mode"></view>
        <view class="course-skeleton__mode"></view>
      </view>
      <view class="course-skeleton__list">
        <view class="course-skeleton__item"><view class="skeleton-line"></view><view class="skeleton-line skeleton-line--translation"></view></view>
        <view class="course-skeleton__item"><view class="skeleton-line skeleton-line--medium"></view><view class="skeleton-line skeleton-line--translation"></view></view>
        <view class="course-skeleton__item"><view class="skeleton-line"></view><view class="skeleton-line skeleton-line--translation"></view></view>
      </view>
    </view>
  </block>

  <block wx:elif="{{error}}">
    <view class="error-container">
      <view class="error-mark">!</view>
      <text class="error-title">课程加载失败</text>
      <text class="error-text">{{error}}</text>
      <button class="retry-btn" bindtap="handleRetry">重新加载</button>
    </view>
  </block>

  <block wx:else>
    <view class="course-header" wx:if="{{course && showModeSelector}}">
      <view class="mode-selector" aria-label="学习阶段">
        <view
          class="mode-btn {{stage === 'listen' ? 'active' : ''}}"
          bindtap="handleStageChange"
          data-stage="listen"
          aria-role="button"
        >
          <text class="mode-text">通听</text>
        </view>
        <view
          class="mode-btn {{stage === 'practice' ? 'active' : ''}}"
          bindtap="handleStageChange"
          data-stage="practice"
          aria-role="button"
        >
          <text class="mode-text">精练</text>
        </view>
        <view
          class="mode-btn {{stage === 'follow' ? 'active' : ''}}"
          bindtap="handleStageChange"
          data-stage="follow"
          aria-role="button"
        >
          <text class="mode-text">跟读</text>
        </view>
      </view>

      <view wx:if="{{stage === 'follow'}}" class="stage-option-row">
        <view
          class="gap-toggle {{gapEnabled ? 'gap-toggle--on' : ''}}"
          bindtap="handleGapToggle"
          aria-role="button"
        >
          <view class="gap-toggle__dot"></view>
          <text class="gap-toggle__text">留白跟读</text>
        </view>
        <text class="stage-option-hint">{{gapWaiting ? '留白中，开口跟读这一句' : (gapEnabled ? '每句后留出等长时间供跟读' : '连续播放，紧跟原声轻声跟读')}}</text>
      </view>
    </view>

    <view
      wx:if="{{stage === 'practice' && starredCueCount > 0}}"
      class="review-filter {{reviewOnlyMode ? 'review-filter--active' : ''}}"
      bindtap="handleReviewOnlyToggle"
      aria-role="button"
    >
      <text class="review-filter__star">★</text>
      <text class="review-filter__label">{{reviewOnlyMode ? '正在只练难句' : '只练难句'}}</text>
      <text class="review-filter__count">{{starredCueCount}} 句</text>
    </view>

    <view
      class="course-content"
      bindtouchstart="handleTouchStart"
      bindtouchmove="handleTouchMove"
      bindtouchend="handleTouchEnd"
      bindtouchcancel="handleTouchEnd"
    >
      <scroll-view
        class="subtitle-scroll"
        scroll-y
        scroll-into-view="{{scrollIntoView}}"
        scroll-top="{{scrollTop}}"
        scroll-with-animation="{{true}}"
      >
        <view class="subtitle-list transcript-mode-{{transcriptMode}}">
          <block wx:if="{{subtitles.length}}">
            <block wx:for="{{subtitles}}" wx:key="id">
              <view
                wx:if="{{!reviewOnlyMode || item.starred}}"
                id="subtitle-{{item.id}}"
                class="subtitle-item {{currentSubtitleId === item.id ? 'active' : ''}} {{item.toneClass}}"
                data-index="{{index}}"
                bindtap="handleSubtitleTap"
                aria-role="button"
              >
              <view class="subtitle-text">
                <block wx:if="{{item.tokens && item.tokens.length}}">
                  <block wx:for="{{item.tokens}}" wx:for-item="token" wx:for-index="tokenIndex" wx:key="tokenIndex">
                    <view
                      wx:if="{{token.isWord}}"
                      id="word-{{item.id}}-{{tokenIndex}}"
                      class="subtitle-word"
                      data-word="{{token.word}}"
                      data-raw="{{token.text}}"
                      data-cue-id="{{item.id}}"
                      data-word-id="word-{{item.id}}-{{tokenIndex}}"
                      catchlongpress="handleWordLongPress"
                      catchtap=""
                    >{{token.text}}</view>
                    <text wx:else class="subtitle-token">{{token.text}}</text>
                  </block>
                </block>
                <text wx:else class="subtitle-text-raw">{{item.text}}</text>
              </view>
              <text wx:if="{{item.translation}}" class="subtitle-translation">{{item.translation}}</text>
              <view wx:if="{{item.starred}}" class="subtitle-star">★</view>

              <view
                wx:if="{{showPracticeControls && stage === 'practice' && currentSubtitleId === item.id}}"
                class="cue-actions"
                catchtap=""
              >
                <view
                  class="cue-action {{item.starred ? 'cue-action--starred' : ''}}"
                  catchtap="handleToggleStar"
                  data-id="{{item.id}}"
                  aria-role="button"
                >{{item.starred ? '★ 已标记' : '☆ 标记难句'}}</view>
                <view
                  class="cue-action {{recording ? 'cue-action--recording' : ''}}"
                  catchtap="handleToggleRecording"
                  aria-role="button"
                >{{recording ? '■ 停止录音' : '● 录音跟读'}}</view>
                <view
                  wx:if="{{recordReady}}"
                  class="cue-action cue-action--primary"
                  catchtap="handleCompareRecording"
                  aria-role="button"
                >{{comparing ? '对比中…' : '▶ 对比听'}}</view>
              </view>
              </view>
            </block>
            <view wx:if="{{reviewOnlyMode && !starredCueCount}}" class="empty-state">
              <text class="empty-title">暂无标记难句</text>
              <text class="empty-text">退出筛选后，在精练阶段标记想复习的句子</text>
            </view>
          </block>

          <view wx:else class="empty-state">
            <text class="empty-title">暂无课程内容</text>
            <text class="empty-text">稍后再试或返回选择其他课程</text>
          </view>
        </view>
      </scroll-view>

      <view
        wx:if="{{wordPopupVisible}}"
        class="word-popup {{wordPopupPlacement === 'bottom' ? 'word-popup-bottom' : ''}} {{wordPopupReady ? 'word-popup-ready' : 'word-popup-hidden'}}"
        style="left: {{wordPopupLeft}}px; top: {{wordPopupTop}}px;"
        id="word-popup"
        catchtap="handleStopPropagation"
      >
        <view class="word-popup-header">
          <text class="word-popup-word">{{wordPopupWord}}</text>
        </view>
        <view class="word-popup-phonetics" wx:if="{{wordPopupPhoneticUk || wordPopupPhoneticUs}}">
          <view class="word-phonetic">
            <text class="phonetic-label">美音</text>
            <text class="phonetic-text">{{wordPopupPhoneticUs}}</text>
            <view wx:if="{{audioPlaybackEnabled && wordPopupAudioUs}}" class="phonetic-audio" hover-class="phonetic-audio-active" hover-stop-propagation data-variant="us" bindtap="handlePlayWordAudio">
              <view class="sound-icon"><view class="sound-icon__wave sound-icon__wave--near"></view><view class="sound-icon__wave sound-icon__wave--far"></view></view>
            </view>
          </view>
          <view class="word-phonetic">
            <text class="phonetic-label">英音</text>
            <text class="phonetic-text">{{wordPopupPhoneticUk}}</text>
            <view wx:if="{{audioPlaybackEnabled && wordPopupAudioUk}}" class="phonetic-audio" hover-class="phonetic-audio-active" hover-stop-propagation data-variant="uk" bindtap="handlePlayWordAudio">
              <view class="sound-icon"><view class="sound-icon__wave sound-icon__wave--near"></view><view class="sound-icon__wave sound-icon__wave--far"></view></view>
            </view>
          </view>
        </view>
        <scroll-view class="word-popup-body" scroll-y>
          <text wx:if="{{wordPopupLoading}}" class="word-popup-loading">正在查询...</text>
          <text wx:elif="{{wordPopupError}}" class="word-popup-error">{{wordPopupError}}</text>
          <text wx:else class="word-popup-definition">{{wordPopupDefinition}}</text>
        </scroll-view>
      </view>
    </view>

    <view class="playback-controls" wx:if="{{subtitles.length}}">
      <view class="controls-row">
        <view wx:if="{{showPracticeControls}}" class="control-item" bindtap="handleExplain" aria-role="button">
          <view class="control-visual">
            <image class="control-line-icon" src="/assets/icons/lightbulb.svg" mode="aspectFit"></image>
          </view>
          <text class="control-label">讲解</text>
        </view>

        <view wx:if="{{showPracticeControls}}" class="control-item {{isRepeating ? 'control-item-active' : ''}}" bindtap="handleRepeat" aria-role="button">
          <view class="control-visual">
            <image class="control-line-icon" src="{{isRepeating ? '/assets/icons/repeat-2-active.svg' : '/assets/icons/repeat-2.svg'}}" mode="aspectFit"></image>
            <text wx:if="{{isRepeating}}" class="repeat-counter">{{repeatCount + 1}}/{{repeatTarget}}</text>
          </view>
          <text class="control-label">{{isRepeating ? '重复中' : '重复'}}</text>
        </view>

        <view wx:if="{{showPracticeControls}}" class="control-item" bindtap="handleShowSpeedModal" aria-role="button">
          <view class="control-visual"><text class="control-value">{{utils.formatSpeed(playbackRate)}}×</text></view>
          <text class="control-label">速度</text>
        </view>

        <view class="control-item" bindtap="handleToggleLanguage" aria-role="button">
          <view class="control-visual">
            <image class="control-line-icon" src="/assets/icons/languages.svg" mode="aspectFit"></image>
          </view>
          <text class="control-label">{{transcriptMode === 'all' ? '双语' : (transcriptMode === 'en' ? '英文' : '中文')}}</text>
        </view>

        <view wx:if="{{showPracticeControls}}" class="control-item" bindtap="handlePlayPause" aria-role="button">
          <view class="control-visual control-visual--play {{playing ? 'playing' : ''}}">
            <view wx:if="{{playing}}" class="pause-symbol"><view class="pause-symbol__bar"></view><view class="pause-symbol__bar"></view></view>
            <view wx:else class="play-symbol"></view>
          </view>
          <text class="control-label">{{playing ? '暂停' : '播放'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{showSpeedModal}}" class="speed-modal" bindtap="handleHideSpeedModal">
      <view class="speed-modal-content" catchtap="">
        <view class="speed-modal-handle"></view>
        <view class="speed-modal-header">
          <text class="speed-modal-title">播放速度</text>
          <text class="speed-modal-value">{{utils.formatSpeed(playbackRate)}}×</text>
        </view>
        <view class="speed-slider-container">
          <text class="speed-label">0.5×</text>
          <slider class="speed-slider" min="50" max="200" step="5" value="{{playbackRate * 100}}" activeColor="{{themeAccent}}" block-size="20" bindchange="handleSpeedChange" />
          <text class="speed-label">2×</text>
        </view>
        <view class="speed-presets">
          <view wx:for="{{speedPresets}}" wx:key="*this" class="speed-preset-btn {{playbackRate === item ? 'active' : ''}}" data-speed="{{item}}" bindtap="handleSpeedPreset">
            {{utils.formatSpeed(item)}}×
          </view>
        </view>
      </view>
    </view>

    <view class="fab-pdf" bindtap="handleOpenPDFPage" aria-role="button" aria-label="知识点">
      <image class="fab-book-icon" src="/assets/icons/book-open-text-primary.svg" mode="aspectFit"></image>
      <text class="fab-text">知识点</text>
    </view>

    <view wx:if="{{showCompletionPanel}}" class="completion-panel">
      <view class="completion-panel__mask" bindtap="handleCompletionClose"></view>
      <view class="completion-panel__card">
        <view class="completion-panel__badge">✓</view>
        <text class="completion-panel__title">本小节完成</text>
        <text class="completion-panel__stats">共 {{completionStats.totalCues}} 句{{completionStats.practicedCount > 0 ? ' · 本次精练 ' + completionStats.practicedCount + ' 句' : ''}}</text>

        <button
          wx:if="{{nextScene}}"
          class="completion-panel__primary"
          bindtap="handleCompletionNext"
        >进入下一节</button>
        <text wx:if="{{nextScene}}" class="completion-panel__next-hint">下一节 · {{nextScene.chapterLabel}}「{{nextScene.title}}」</text>

        <view class="completion-panel__secondary-row">
          <button class="completion-panel__secondary" bindtap="handleCompletionReplay">再听一遍</button>
          <button class="completion-panel__secondary" open-type="share">分享给同事</button>
        </view>

        <text class="completion-panel__dismiss" bindtap="handleCompletionClose">留在本节继续练</text>
      </view>
    </view>

    <view wx:if="{{showStageGuide}}" class="stage-guide">
      <view class="stage-guide__mask"></view>
      <view class="stage-guide__card">
        <text class="stage-guide__title">三步练熟一个场景</text>
        <view class="stage-guide__step">
          <text class="stage-guide__step-label">1 通听</text>
          <text class="stage-guide__step-desc">连续播放，边听边看，了解对话大意</text>
        </view>
        <view class="stage-guide__step">
          <text class="stage-guide__step-label">2 精练</text>
          <text class="stage-guide__step-desc">逐句播放，不熟的句子重复听、跟着读</text>
        </view>
        <view class="stage-guide__step">
          <text class="stage-guide__step-label">3 跟读</text>
          <text class="stage-guide__step-desc">再次连续播放，紧跟原声流利跟读，可开启留白</text>
        </view>
        <text class="stage-guide__tip">点按句子播放，长按单词查释义</text>
        <button class="stage-guide__button" bindtap="dismissStageGuide">开始学习</button>
      </view>
    </view>

    <ai-popup show="{{showAiPopup}}" text="{{aiText}}" context="{{aiContext}}" bind:close="handleAiPopupClose" />
  </block>
</view>

<canvas
  canvas-id="course-share-canvas"
  class="course-share-canvas"
  style="width: 600px; height: 840px;"
></canvas>
</view>
