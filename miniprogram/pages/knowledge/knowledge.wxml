<navigation-bar
  title="{{courseTitle}}"
  back="{{true}}"
  color="black"
  background="#FFF"
></navigation-bar>

<view class="knowledge-page">
  <block wx:if="{{loading}}">
    <view class="state state--loading">
      <view class="spinner"></view>
      <text>加载中...</text>
    </view>
  </block>

  <block wx:elif="{{error}}">
    <view class="state">
      <text class="state__title">{{error}}</text>
      <button class="retry-btn" bindtap="handleRetry">重试</button>
    </view>
  </block>

  <scroll-view wx:else class="knowledge-scroll" scroll-y>
    <view class="knowledge-content">
      <view wx:if="{{backgroundParagraphs.length}}" class="knowledge-card knowledge-card--background">
        <view class="knowledge-card__head">
          <text class="knowledge-card__title">场景背景</text>
        </view>
        <view class="knowledge-paragraph-list">
          <text
            wx:for="{{backgroundParagraphs}}"
            wx:key="id"
            class="knowledge-paragraph"
            user-select
          >{{item.text}}</text>
        </view>
      </view>

      <view wx:if="{{phraseItems.length}}" class="knowledge-card">
        <view class="knowledge-card__head knowledge-card__head--inline">
          <view>
            <text class="knowledge-card__title">词汇和句型</text>
          </view>
        </view>
        <view class="phrase-list">
          <view wx:for="{{phraseItems}}" wx:key="id" class="phrase-item">
            <text wx:if="{{item.term}}" class="phrase-item__term" user-select>{{item.term}}</text>
            <text class="phrase-item__definition" user-select>{{item.definition}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{correction.hasContent}}" class="knowledge-card knowledge-card--correction">
        <view class="knowledge-card__head">
          <text class="knowledge-card__title">中式英语纠错</text>
        </view>
        <view wx:if="{{correction.promptLines.length}}" class="correction-prompt">
          <text
            wx:for="{{correction.promptLines}}"
            wx:key="id"
            class="correction-prompt__text"
            user-select
          >{{item.text}}</text>
        </view>
        <view wx:if="{{correction.chinglishLines.length}}" class="correction-example correction-example--bad">
          <text class="correction-label">Chinglish</text>
          <text
            wx:for="{{correction.chinglishLines}}"
            wx:key="id"
            class="correction-text"
            user-select
          >{{item.text}}</text>
        </view>
        <view wx:if="{{correction.nativeLines.length}}" class="correction-example correction-example--good">
          <text class="correction-label">Native English</text>
          <text
            wx:for="{{correction.nativeLines}}"
            wx:key="id"
            class="correction-text"
            user-select
          >{{item.text}}</text>
        </view>
        <view wx:if="{{correction.extraLines.length}}" class="knowledge-paragraph-list">
          <text
            wx:for="{{correction.extraLines}}"
            wx:key="id"
            class="knowledge-paragraph"
            user-select
          >{{item.text}}</text>
        </view>
      </view>

      <view wx:if="{{noteParagraphs.length}}" class="knowledge-card">
        <view class="knowledge-card__head">
          <text class="knowledge-card__title">毅冰补充</text>
        </view>
        <view class="knowledge-paragraph-list">
          <text
            wx:for="{{noteParagraphs}}"
            wx:key="id"
            class="knowledge-paragraph"
            user-select
          >{{item.text}}</text>
        </view>
      </view>

      <view wx:if="{{dialogue.length}}" class="dialogue-section">
        <view class="knowledge-card__head">
          <text class="knowledge-card__title">对话原文</text>
        </view>
        <view wx:for="{{dialogue}}" wx:key="id" class="dialogue-item {{index == 0 ? 'dialogue-item--first' : ''}} {{item.toneClass}}">
          <text class="dialogue-item__speaker">{{item.speaker}}</text>
          <view class="dialogue-item__body">
            <view class="dialogue-segment-list">
              <text
                wx:for="{{item.textSegments}}"
                wx:for-item="segment"
                wx:key="id"
                class="dialogue-segment dialogue-segment--text {{item.toneClass}}"
                user-select
              >{{segment.text}}</text>
            </view>
            <view wx:if="{{item.translationSegments.length}}" class="dialogue-segment-list dialogue-segment-list--translation">
              <text
                wx:for="{{item.translationSegments}}"
                wx:for-item="segment"
                wx:key="id"
                class="dialogue-segment dialogue-segment--translation {{item.toneClass}}"
                user-select
              >{{segment.text}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
