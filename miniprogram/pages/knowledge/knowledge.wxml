<view class="app-page">
<navigation-bar
  title="{{courseTitle}}"
  back="{{true}}"
  color="black"
  background="#F5F7FB"
></navigation-bar>

<view class="knowledge-page">
  <view wx:if="{{loading}}" class="knowledge-skeleton" aria-label="知识点加载中">
    <view class="knowledge-skeleton__section"><view class="skeleton-title"></view><view class="skeleton-line"></view><view class="skeleton-line skeleton-line--short"></view></view>
    <view class="knowledge-skeleton__section"><view class="skeleton-title"></view><view class="skeleton-row"></view><view class="skeleton-row"></view><view class="skeleton-row"></view></view>
  </view>

  <view wx:elif="{{error}}" class="state">
    <view class="state__mark">!</view>
    <text class="state__title">知识点加载失败</text>
    <text class="state__desc">{{error}}</text>
    <button class="retry-btn" bindtap="handleRetry">重新加载</button>
  </view>

  <view wx:elif="{{isEmpty}}" class="state">
    <text class="state__title">暂无知识点</text>
    <text class="state__desc">这节课的知识点内容还在整理中</text>
  </view>

  <scroll-view wx:else class="knowledge-scroll" scroll-y>
    <view class="knowledge-content">
      <view wx:if="{{backgroundParagraphs.length}}" class="knowledge-section knowledge-section--intro">
        <view class="section-heading">
          <view class="section-heading__line"></view>
          <text class="section-heading__title">场景背景</text>
        </view>
        <view class="knowledge-paragraph-list">
          <text wx:for="{{backgroundParagraphs}}" wx:key="id" class="knowledge-paragraph" user-select>{{item.text}}</text>
        </view>
      </view>

      <view wx:if="{{phraseItems.length}}" class="knowledge-section">
        <view class="section-heading">
          <view class="section-heading__line"></view>
          <text class="section-heading__title">词汇和句型</text>
        </view>
        <view class="phrase-list">
          <view wx:for="{{phraseItems}}" wx:key="id" class="phrase-item">
            <text wx:if="{{item.term}}" class="phrase-item__term" user-select>{{item.term}}</text>
            <text class="phrase-item__definition" user-select>{{item.definition}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{correction.hasContent}}" class="knowledge-section">
        <view class="section-heading">
          <view class="section-heading__line"></view>
          <text class="section-heading__title">中式英语纠错</text>
        </view>
        <view wx:if="{{correction.promptLines.length}}" class="correction-prompt">
          <text wx:for="{{correction.promptLines}}" wx:key="id" class="correction-prompt__text" user-select>{{item.text}}</text>
        </view>
        <view wx:if="{{correction.chinglishLines.length}}" class="correction-example correction-example--bad">
          <text class="correction-label">中式表达</text>
          <text wx:for="{{correction.chinglishLines}}" wx:key="id" class="correction-text" user-select>{{item.text}}</text>
        </view>
        <view wx:if="{{correction.nativeLines.length}}" class="correction-example correction-example--good">
          <text class="correction-label">更自然的表达</text>
          <text wx:for="{{correction.nativeLines}}" wx:key="id" class="correction-text" user-select>{{item.text}}</text>
        </view>
        <view wx:if="{{correction.extraLines.length}}" class="knowledge-paragraph-list correction-extra">
          <text wx:for="{{correction.extraLines}}" wx:key="id" class="knowledge-paragraph" user-select>{{item.text}}</text>
        </view>
      </view>

      <view wx:if="{{noteParagraphs.length}}" class="knowledge-section">
        <view class="section-heading">
          <view class="section-heading__line"></view>
          <text class="section-heading__title">毅冰补充</text>
        </view>
        <view class="knowledge-paragraph-list">
          <text wx:for="{{noteParagraphs}}" wx:key="id" class="knowledge-paragraph" user-select>{{item.text}}</text>
        </view>
      </view>

      <view wx:if="{{dialogue.length}}" class="knowledge-section knowledge-section--dialogue">
        <view class="section-heading">
          <view class="section-heading__line"></view>
          <text class="section-heading__title">对话原文</text>
        </view>
        <view class="dialogue-list">
          <view wx:for="{{dialogue}}" wx:key="id" class="dialogue-item {{item.toneClass}}">
            <text class="dialogue-item__speaker">{{item.speaker}}</text>
            <view class="dialogue-item__body">
              <view wx:for="{{item.sentences}}" wx:for-item="sentence" wx:key="id" class="dialogue-pair {{item.toneClass}}">
                <text wx:if="{{sentence.text}}" class="dialogue-pair__text" user-select>{{sentence.text}}</text>
                <text wx:if="{{sentence.translation}}" class="dialogue-pair__translation" user-select>{{sentence.translation}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
</view>
