<view class="app-page">
  <navigation-bar title="我的" back="{{false}}" color="black" background="#F5F7FB"></navigation-bar>
  <scroll-view class="learning-scroll" scroll-y>
    <view class="learning-page">
      <view wx:if="{{isAuthenticated}}" class="learning-profile">
        <view class="learning-profile__avatar {{avatarUrl ? 'learning-profile__avatar--image' : ''}}">
          <image wx:if="{{avatarUrl}}" class="learning-profile__avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
          <text wx:else>{{avatarInitial}}</text>
        </view>
        <view class="learning-profile__copy">
          <text class="learning-profile__eyebrow">MY LEARNING</text>
          <text class="learning-profile__name">{{nickname}}</text>
          <text class="learning-profile__desc">每一次开口，都算进你的学习记录</text>
        </view>
      </view>

      <view wx:else class="account-guest">
        <view class="account-guest__mark">MY</view>
        <text class="account-guest__title">登录后查看学习记录</text>
        <text class="account-guest__desc">记录连续学习、完成小节和累计练习时长</text>
        <button class="account-guest__button" bindtap="goToLogin">微信登录</button>
      </view>

      <view wx:if="{{isAuthenticated}}" class="learning-overview">
        <view class="learning-overview__heading">
          <text class="learning-overview__title">学习概览</text>
          <text class="learning-overview__hint">每次练习后自动更新</text>
        </view>
        <view class="learning-overview__duration">
          <text class="learning-overview__duration-label">累计练习时长</text>
          <text class="learning-overview__duration-value">{{studyDurationLabel}}</text>
        </view>
        <view class="learning-overview__metrics">
          <view class="learning-metric">
            <view class="learning-metric__value-row"><text class="learning-metric__value">{{streakCount}}</text><text class="learning-metric__unit">天</text></view>
            <text class="learning-metric__label">连续学习</text>
          </view>
          <view class="learning-metric learning-metric--completed">
            <view class="learning-metric__value-row"><text class="learning-metric__value">{{totalCompleted}}</text><text class="learning-metric__unit">节</text></view>
            <text class="learning-metric__label">已完成小节</text>
          </view>
        </view>
      </view>

      <view wx:if="{{isAuthenticated}}" class="record-section">
        <view class="record-section__heading">
          <view><text class="record-section__title">最近 4 周</text><text class="record-section__desc">有练习的日子会被点亮</text></view>
          <view class="record-section__meta"><text>{{activeDays}} 天活跃</text><text>{{totalPracticeCount}} 次精练</text></view>
        </view>

        <view wx:if="{{loading}}" class="record-loading">正在加载学习记录…</view>
        <view wx:elif="{{error}}" class="record-error">
          <text>{{error}}</text><button class="record-error__button" bindtap="handleRetry">重新加载</button>
        </view>
        <view wx:else class="calendar-card">
          <view class="calendar-weekdays"><text>一</text><text>二</text><text>三</text><text>四</text><text>五</text><text>六</text><text>日</text></view>
          <view class="calendar-grid">
            <view wx:for="{{calendar}}" wx:key="date" class="calendar-day calendar-day--{{item.intensity}} {{item.isToday ? 'calendar-day--today' : ''}}">
              <text>{{item.dayLabel}}</text>
            </view>
          </view>
          <view class="calendar-legend"><text>少</text><view class="legend-dot calendar-day--1"></view><view class="legend-dot calendar-day--2"></view><view class="legend-dot calendar-day--3"></view><text>多</text></view>
        </view>
      </view>

      <view class="service-section">
        <text class="service-section__title">服务与支持</text>
        <view class="service-card">
          <view class="service-row" bindtap="goToUnlock" aria-role="button">
            <view class="service-row__mark service-row__mark--member"><image class="service-row__icon" src="/assets/icons/membership-badge.svg" mode="aspectFit"></image></view>
            <view class="service-row__copy"><text class="service-row__title">会员权益</text><text class="service-row__desc">{{membershipLabel}}</text></view>
            <text class="service-row__arrow">›</text>
          </view>
          <view class="service-row" bindtap="goToPracticeHelp" aria-role="button">
            <view class="service-row__mark"><image class="service-row__icon" src="/assets/icons/practice-method.svg" mode="aspectFit"></image></view>
            <view class="service-row__copy"><text class="service-row__title">练习方法</text><text class="service-row__desc">通听、精练、跟读怎么配合</text></view>
            <text class="service-row__arrow">›</text>
          </view>
          <view class="service-row service-row--last" bindtap="goToContact" aria-role="button">
            <view class="service-row__mark"><image class="service-row__icon" src="/assets/icons/feedback-message.svg" mode="aspectFit"></image></view>
            <view class="service-row__copy"><text class="service-row__title">交流与反馈</text><text class="service-row__desc">加入交流群或提交使用建议</text></view>
            <text class="service-row__arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
