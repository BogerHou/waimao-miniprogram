<view class="app-page">
<navigation-bar title="练习方法" back="{{true}}" color="black" background="#F5F7FB"></navigation-bar>

<scroll-view class="help-scroll" scroll-y>
  <view class="help-page">
    <view class="help-hero">
      <text class="help-hero__eyebrow">THREE-STAGE PRACTICE</text>
      <text class="help-hero__title">一节课，按三步练熟</text>
      <text class="help-hero__desc">通听理解场景，精练解决难句，最后连续跟读。每次只完成当前阶段的目标。</text>
      <view class="help-hero__route">
        <text>通听</text><view class="help-hero__line"></view><text>精练</text><view class="help-hero__line"></view><text>跟读</text>
      </view>
    </view>

    <view class="stage-list">
      <view wx:for="{{stageSteps}}" wx:key="label" class="stage-card">
        <view class="stage-card__header">
          <text class="stage-card__label">{{item.label}}</text>
          <view class="stage-card__heading">
            <text class="stage-card__title">{{item.title}}</text>
            <text class="stage-card__subtitle">{{item.subtitle}}</text>
          </view>
        </view>
        <text class="stage-card__desc">{{item.desc}}</text>
        <text class="stage-card__action">{{item.action}}</text>
      </view>
    </view>

    <view class="help-section">
      <view class="section-heading">
        <text class="section-heading__title">卡住时这样处理</text>
        <text class="section-heading__desc">一次只解决一个最明显的问题</text>
      </view>
      <view class="tip-list">
        <view wx:for="{{practiceTips}}" wx:key="title" class="tip-item">
          <view class="tip-item__dot"></view>
          <view class="tip-item__body">
            <text class="tip-item__title">{{item.title}}</text>
            <text class="tip-item__desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="help-section">
      <view class="section-heading">
        <text class="section-heading__title">练到什么程度算有效</text>
      </view>
      <view class="checkpoint-list">
        <view wx:for="{{checkpoints}}" wx:key="title" class="checkpoint-item">
          <icon class="checkpoint-item__icon" type="success_no_circle" size="18" color="#16a34a" />
          <view class="checkpoint-item__body">
            <text class="checkpoint-item__title">{{item.title}}</text>
            <text class="checkpoint-item__desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="help-actions">
      <button class="help-action help-action--primary" bindtap="goToCourses">去选一节课</button>
      <button class="help-action help-action--secondary" open-type="share">分享练习方法</button>
    </view>
  </view>
</scroll-view>

<canvas
  canvas-id="practice-help-share-canvas"
  class="share-poster-canvas"
  style="width: 600px; height: 840px;"
></canvas>
</view>
