.profile-edit-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx;
}

.profile-edit-header {
  margin-bottom: 48rpx;
}

.profile-edit-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.profile-edit-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

/* 头像选择 */
.avatar-button {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  background: transparent;
  border: none;
  overflow: hidden;
}

.avatar-button::after {
  border: none;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.avatar-button:active .avatar-overlay {
  opacity: 1;
}

.avatar-text {
  font-size: 24rpx;
  color: #fff;
}

/* 昵称输入 */
.nickname-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.nickname-input:focus {
  border-color: #1989fa;
}

/* 按钮 */
.profile-edit-actions {
  margin-top: 48rpx;
  display: flex;
  gap: 24rpx;
}

.save-button,
.cancel-button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.save-button {
  background: #1989fa;
  color: #fff;
}

.save-button:disabled {
  background: #e0e0e0;
  color: #999;
}

.cancel-button {
  background: #fff;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

.save-button::after,
.cancel-button::after {
  border: none;
}
