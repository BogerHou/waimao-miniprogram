<view class="app-page">
  <navigation-bar title="复习" back="{{false}}" color="black" background="#F5F7FB"></navigation-bar>
  <view class="review-page">
    <view class="review-tabs">
      <view class="review-tab {{tab === 'words' ? 'review-tab--active' : ''}}" data-tab="words" bindtap="handleTabChange">
        <text>生词</text><text class="review-tab__count">{{wordCount}}</text>
      </view>
      <view class="review-tab {{tab === 'cues' ? 'review-tab--active' : ''}}" data-tab="cues" bindtap="handleTabChange">
        <text>难句</text><text class="review-tab__count">{{cueCount}}</text>
      </view>
    </view>

    <scroll-view class="review-scroll" scroll-y>
      <view wx:if="{{tab === 'words'}}" class="review-list">
        <view wx:for="{{words}}" wx:key="normalized" class="word-card">
          <view class="word-card__top">
            <view class="word-card__identity">
              <text class="word-card__word">{{item.word}}</text>
              <text wx:if="{{item.phoneticUs || item.phoneticUk}}" class="word-card__phonetic">{{item.phoneticUs || item.phoneticUk}}</text>
            </view>
            <view class="word-card__actions">
              <view
                wx:if="{{item.audioUs || item.audioUk}}"
                class="audio-control {{activeAudioType === 'word' && activeAudioId === item.normalized ? 'audio-control--active' : ''}}"
                data-id="{{item.normalized}}"
                data-url="{{item.audioUs || item.audioUk}}"
                catchtap="handlePlayWordAudio"
                aria-role="button"
                aria-label="播放单词发音"
              >
                <view class="audio-control__visual">
                  <view wx:if="{{activeAudioType === 'word' && activeAudioId === item.normalized && audioStatus === 'loading'}}" class="audio-control__spinner"></view>
                  <view wx:elif="{{activeAudioType === 'word' && activeAudioId === item.normalized && audioStatus === 'playing'}}" class="audio-control__pause"><view class="audio-control__pause-bar"></view><view class="audio-control__pause-bar"></view></view>
                  <view wx:else class="audio-control__play"></view>
                </view>
                <text>{{activeAudioType === 'word' && activeAudioId === item.normalized ? (audioStatus === 'loading' ? '加载中' : (audioStatus === 'playing' ? '暂停' : (audioStatus === 'paused' ? '继续' : '发音'))) : '发音'}}</text>
              </view>
              <view class="review-remove" data-id="{{item.normalized}}" catchtap="handleDeleteWord" aria-role="button" aria-label="移除生词">
                <image class="review-remove__icon" src="/assets/icons/trash-2.svg" mode="aspectFit"></image>
              </view>
            </view>
          </view>
          <text class="word-card__definition">{{item.definition || '暂无释义'}}</text>
          <view wx:if="{{item.cueText}}" class="source-quote">
            <view class="source-quote__meta"><text>例句</text><text class="source-quote__course">{{item.courseTitle || '来源课程'}}</text></view>
            <text class="source-quote__text">{{item.cueText}}</text>
            <text wx:if="{{item.cueTranslation}}" class="source-quote__translation">{{item.cueTranslation}}</text>
          </view>
        </view>
        <view wx:if="{{!words.length}}" class="review-empty">
          <text class="review-empty__mark">Aa</text>
          <text class="review-empty__title">还没有生词</text>
          <text class="review-empty__desc">课程里长按单词，查过的词会保存在这里</text>
        </view>
      </view>

      <view wx:else class="review-list">
        <view wx:for="{{cues}}" wx:key="audioId" class="cue-card">
          <text class="cue-card__text">{{item.cueText || '句子暂未同步'}}</text>
          <text wx:if="{{item.cueTranslation}}" class="cue-card__translation">{{item.cueTranslation}}</text>
          <view class="cue-card__footer">
            <text class="cue-card__course">{{item.courseTitle || item.courseId}}</text>
            <view class="cue-card__actions">
              <view
                class="audio-control {{activeAudioType === 'cue' && activeAudioId === item.audioId ? 'audio-control--active' : ''}}"
                data-audio-id="{{item.audioId}}"
                data-course-id="{{item.courseId}}"
                data-cue-id="{{item.cueId}}"
                catchtap="handlePlayCueAudio"
                aria-role="button"
                aria-label="播放句子原声"
              >
                <view class="audio-control__visual">
                  <view wx:if="{{activeAudioType === 'cue' && activeAudioId === item.audioId && audioStatus === 'loading'}}" class="audio-control__spinner"></view>
                  <view wx:elif="{{activeAudioType === 'cue' && activeAudioId === item.audioId && audioStatus === 'playing'}}" class="audio-control__pause"><view class="audio-control__pause-bar"></view><view class="audio-control__pause-bar"></view></view>
                  <view wx:else class="audio-control__play"></view>
                </view>
                <text>{{activeAudioType === 'cue' && activeAudioId === item.audioId ? (audioStatus === 'loading' ? '加载中' : (audioStatus === 'playing' ? '暂停' : (audioStatus === 'paused' ? '继续' : '听原声'))) : '听原声'}}</text>
              </view>
              <view class="review-remove" data-course-id="{{item.courseId}}" data-cue-id="{{item.cueId}}" catchtap="handleDeleteCue" aria-role="button" aria-label="移除难句">
                <image class="review-remove__icon" src="/assets/icons/trash-2.svg" mode="aspectFit"></image>
              </view>
            </view>
          </view>
        </view>
        <view wx:if="{{!cues.length && !loading}}" class="review-empty">
          <text class="review-empty__mark review-empty__mark--star">★</text>
          <text class="review-empty__title">还没有难句</text>
          <text class="review-empty__desc">在精练中点亮星标，难句会保存在这里</text>
        </view>
        <view wx:if="{{loading}}" class="review-loading">正在同步难句…</view>
      </view>
    </scroll-view>
  </view>
</view>
