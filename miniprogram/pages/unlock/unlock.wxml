<view class="app-page">
<navigation-bar
  title="解锁课程"
  back="{{true}}"
  color="black"
  background="#F5F7FB"
></navigation-bar>

<scroll-view class="unlock-scroll" scroll-y>
  <view class="unlock-page">
    <view wx:if="{{fullAccess}}" class="unlock-success">
      <view class="unlock-success__card">
        <view class="unlock-success__seal">✓</view>
        <text class="unlock-success__eyebrow">MEMBERSHIP ACTIVE</text>
        <text class="unlock-success__title">全部课程已解锁</text>
        <text class="unlock-success__desc">7 章外贸场景课程，现在都可以学习</text>
        <view class="unlock-success__expiry">{{expiresAtLabel}}</view>
      </view>
      <button class="unlock-primary" bindtap="goHome" hover-class="unlock-primary--pressed">开始学习</button>
      <text class="unlock-success__tip">学习进度会自动保存</text>
    </view>

    <block wx:else>
      <view class="membership-pass">
        <view class="membership-pass__glow membership-pass__glow--top"></view>
        <view class="membership-pass__glow membership-pass__glow--bottom"></view>

        <view class="membership-pass__topline">
          <text class="membership-pass__eyebrow">FULL ACCESS</text>
          <text class="membership-pass__term">365 DAYS</text>
        </view>

        <text class="membership-pass__title">解锁完整外贸英语课程</text>
        <text class="membership-pass__desc">从电话沟通到谈判售后，把真实业务场景一次学全</text>

        <view class="membership-pass__stats">
          <view class="membership-stat">
            <text class="membership-stat__value">7</text>
            <text class="membership-stat__label">章课程</text>
          </view>
          <view class="membership-stat">
            <text class="membership-stat__value">50</text>
            <text class="membership-stat__label">个场景</text>
          </view>
          <view class="membership-stat">
            <text class="membership-stat__value">1</text>
            <text class="membership-stat__label">年有效</text>
          </view>
        </view>

        <view class="membership-pass__features">
          <text class="membership-pass__feature">逐句精练</text>
          <text class="membership-pass__dot">·</text>
          <text class="membership-pass__feature">录音对比</text>
          <text class="membership-pass__dot">·</text>
          <text class="membership-pass__feature">知识点讲解</text>
        </view>
      </view>

      <view class="unlock-flow">
        <view class="unlock-section unlock-section--contact">
          <view class="unlock-section__heading">
            <text class="unlock-section__step">01</text>
            <view class="unlock-section__copy">
              <text class="unlock-section__eyebrow">还没有邀请码</text>
              <text class="unlock-section__title">{{contactTitle}}</text>
              <text class="unlock-section__desc">添加后发送“小程序会员”，购买后获取专属邀请码</text>
            </view>
          </view>

          <view class="contact-card">
            <view class="wechat-qr" bindtap="previewContactQr" aria-role="button" aria-label="预览购买微信二维码">
              <image wx:if="{{contactQrUrl}}" class="wechat-qr__image" src="{{contactQrUrl}}" mode="widthFix" show-menu-by-longpress="{{true}}" />
              <view wx:else class="wechat-qr__placeholder">二维码暂未配置</view>
              <view wx:if="{{contactQrUrl}}" class="wechat-qr__zoom">点击放大</view>
            </view>

            <view class="contact-card__copy">
              <view class="contact-card__badge">微信购买</view>
              <text class="contact-card__title">扫码添加购买微信</text>
              <text class="contact-card__desc">{{contactTip}}</text>
              <view class="contact-card__notes">
                <text class="contact-card__note">购买后发放邀请码</text>
                <text class="contact-card__note">兑换后立即生效</text>
              </view>
            </view>
          </view>
        </view>

        <view class="unlock-divider">
          <view class="unlock-divider__line"></view>
          <text class="unlock-divider__text">已经拿到邀请码？</text>
          <view class="unlock-divider__line"></view>
        </view>

        <view class="unlock-section unlock-section--redeem">
          <view class="unlock-section__heading">
            <text class="unlock-section__step unlock-section__step--accent">02</text>
            <view class="unlock-section__copy">
              <text class="unlock-section__eyebrow">已有邀请码</text>
              <text class="unlock-section__title">兑换全年学习权限</text>
              <text class="unlock-section__desc">输入购买后收到的小程序专用邀请码</text>
            </view>
          </view>

          <view class="redeem-box {{codeError ? 'redeem-box--error' : ''}}">
            <text class="redeem-box__label">INVITE CODE</text>
            <input
              class="unlock-input"
              value="{{code}}"
              placeholder="请输入会员邀请码"
              bindinput="handleCodeInput"
              confirm-type="done"
              maxlength="40"
              aria-label="会员邀请码"
            />
          </view>
          <text wx:if="{{codeError}}" class="unlock-error">{{codeError}}</text>

          <button
            class="unlock-primary {{!code || submitting || authLoading ? 'unlock-primary--disabled' : ''}}"
            bindtap="handleRedeem"
            loading="{{submitting || authLoading}}"
            disabled="{{!code || submitting || authLoading}}"
            hover-class="unlock-primary--pressed"
          >解锁全部课程</button>
          <text class="redeem-note">邀请码仅用于本小程序，不会自动续费</text>
        </view>
      </view>
    </block>
  </view>
</scroll-view>
</view>
